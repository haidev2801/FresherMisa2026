{
  "info": {
    "name": "Task-3.2- Xử lý Race Condition khi tạo nhân viên",
    "_postman_id": "task-3-2-race-condition",
    "description": "Test xử lý race condition khi 2 request POST cùng lúc với cùng EmployeeCode.\n\n## Hướng dẫn test\n1. Chạy request **[POST] Tạo nhân viên thành công** trước để khởi tạo dữ liệu test động.\n2. Chạy request **[POST] Tạo nhân viên trùng Code (sequential)** để kiểm tra duplicate theo luồng tuần tự (kỳ vọng 400).\n3. Chạy đồng thời 2 request race (**Request 1** và **Request 2**) với cùng mã được sinh tự động.\n4. Kỳ vọng race: 1 request HTTP 201, 1 request HTTP 400 \"Mã nhân viên đã tồn tại\".\n\nGhi chú: Collection dùng biến `collBaseUrl` để tránh bị override bởi Environment `baseUrl`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "collBaseUrl",
      "value": "http://localhost:5237",
      "type": "string"
    },
    {
      "key": "raceDepartmentId",
      "value": "11111111-1111-1111-1111-111111111111",
      "type": "string"
    },
    {
      "key": "racePositionId",
      "value": "22222222-2222-2222-2222-222222222222",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Smoke Test – API Health",
      "item": [
        {
          "name": "[GET] Danh sách nhân viên",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{collBaseUrl}}/api/Employees",
              "host": [
                "{{collBaseUrl}}"
              ],
              "path": [
                "api",
                "Employees"
              ]
            },
            "description": "Kiểm tra API đang hoạt động. Kỳ vọng: 200 OK, trả về danh sách nhân viên."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Happy Path",
      "item": [
        {
          "name": "[POST] Tạo nhân viên thành công",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function genGuid() {",
                  "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
                  "    const r = Math.random() * 16 | 0;",
                  "    const v = c === 'x' ? r : ((r & 0x3) | 0x8);",
                  "    return v.toString(16);",
                  "  });",
                  "}",
                  "const runId = Date.now().toString().slice(-8);",
                  "pm.collectionVariables.set('happyEmployeeCode', `EMP_HAPPY_${runId}`);",
                  "pm.collectionVariables.set('raceEmployeeCode', `EMP_RACE_${runId}`);",
                  "pm.collectionVariables.set('happyEmployeeId', genGuid());",
                  "pm.collectionVariables.set('raceEmployeeId1', genGuid());",
                  "pm.collectionVariables.set('raceEmployeeId2', genGuid());",
                  "pm.collectionVariables.unset('employeeIdHappy01');",
                  "pm.collectionVariables.unset('employeeIdRace001');",
                  "pm.collectionVariables.unset('employeeIdRace002');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response có dữ liệu nhân viên', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.isSuccess ?? json.IsSuccess).to.be.true;",
                  "    pm.collectionVariables.set('employeeIdHappy01', pm.collectionVariables.get('happyEmployeeId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeID\": \"{{happyEmployeeId}}\",\n  \"employeeCode\": \"{{happyEmployeeCode}}\",\n  \"employeeName\": \"Nguyen Van Test\",\n  \"gender\": 1,\n  \"dateOfBirth\": \"1995-01-15\",\n  \"phoneNumber\": \"0912345001\",\n  \"email\": \"happy01@misa.com\",\n  \"address\": \"Ha Noi\",\n  \"departmentID\": \"{{raceDepartmentId}}\",\n  \"positionID\": \"{{racePositionId}}\",\n  \"salary\": 15000000,\n  \"hireDate\": \"2024-03-01\"\n}"
            },
            "url": {
              "raw": "{{collBaseUrl}}/api/Employees",
              "host": [
                "{{collBaseUrl}}"
              ],
              "path": [
                "api",
                "Employees"
              ]
            },
            "description": "Tạo nhân viên mới hợp lệ với employeeCode động. Kỳ vọng: 201 Created và lưu employeeId để cleanup."
          },
          "response": []
        },
        {
          "name": "[POST] Tạo nhân viên trùng Code (sequential)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 BadRequest vì trùng code', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Message chứa \"Mã nhân viên đã tồn tại\"', function () {",
                  "    const json = pm.response.json();",
                  "    const message = json.userMessage ?? json.UserMessage ?? json.data ?? json.Data ?? '';",
                  "    pm.expect(String(message)).to.include('Mã nhân viên đã tồn tại');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeID\": \"{{happyEmployeeId}}\",\n  \"employeeCode\": \"{{happyEmployeeCode}}\",\n  \"employeeName\": \"Trung Code Test\",\n  \"gender\": 0,\n  \"dateOfBirth\": \"1998-05-20\",\n  \"phoneNumber\": \"0987654002\",\n  \"email\": \"dup01@misa.com\",\n  \"address\": \"HCM\",\n  \"departmentID\": \"{{raceDepartmentId}}\",\n  \"positionID\": \"{{racePositionId}}\",\n  \"salary\": 12000000,\n  \"hireDate\": \"2024-06-01\"\n}"
            },
            "url": {
              "raw": "{{collBaseUrl}}/api/Employees",
              "host": [
                "{{collBaseUrl}}"
              ],
              "path": [
                "api",
                "Employees"
              ]
            },
            "description": "Gửi request với EmployeeCode đã tồn tại theo kiểu tuần tự. Kỳ vọng: 400 BadRequest với message nghiệp vụ \"Mã nhân viên đã tồn tại\"."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Race Condition Test",
      "item": [
        {
          "name": "[Race] Request 1 – POST EMP_RACE_DYNAMIC",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Một trong 2 request phải 201, một phải 400",
                  "pm.test('Phải là 201 hoặc 400', function () {",
                  "    pm.expect([201, 400]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    pm.test('[Race R1] Thành công – nhân viên được tạo', function () {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json.isSuccess ?? json.IsSuccess).to.be.true;",
                  "        pm.collectionVariables.set('employeeIdRace001', pm.collectionVariables.get('raceEmployeeId1'));",
                  "    });",
                  "    console.log('REQUEST 1: THÀNH CÔNG (201)');",
                  "}",
                  "",
                  "if (pm.response.code === 400) {",
                  "    pm.test('[Race R1] Bị reject – trùng code', function () {",
                  "        const json = pm.response.json();",
                  "        const message = json.userMessage ?? json.UserMessage ?? json.data ?? json.Data ?? '';",
                  "        pm.expect(String(message)).to.include('Mã nhân viên đã tồn tại');",
                  "    });",
                  "    console.log('REQUEST 1: BỊ REJECT (400)');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeID\": \"{{raceEmployeeId1}}\",\n  \"employeeCode\": \"{{raceEmployeeCode}}\",\n  \"employeeName\": \"Race Test Nhan Vien 1\",\n  \"gender\": 1,\n  \"dateOfBirth\": \"1996-08-10\",\n  \"phoneNumber\": \"0911000001\",\n  \"email\": \"race1@misa.com\",\n  \"address\": \"Ha Noi\",\n  \"departmentID\": \"{{raceDepartmentId}}\",\n  \"positionID\": \"{{racePositionId}}\",\n  \"salary\": 16000000,\n  \"hireDate\": \"2025-01-01\"\n}"
            },
            "url": {
              "raw": "{{collBaseUrl}}/api/Employees",
              "host": [
                "{{collBaseUrl}}"
              ],
              "path": [
                "api",
                "Employees"
              ]
            },
            "description": "⚠️ Chạy ĐỒNG THỜI với Request 2. Cùng employeeCode động `{{raceEmployeeCode}}`.\n\nKỳ vọng: Một trong hai request trả về 201, request còn lại trả về 400 \"Mã nhân viên đã tồn tại\"."
          },
          "response": []
        },
        {
          "name": "[Race] Request 2 – POST EMP_RACE_DYNAMIC (cùng code)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Một trong 2 request phải 201, một phải 400",
                  "pm.test('Phải là 201 hoặc 400', function () {",
                  "    pm.expect([201, 400]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    pm.test('[Race R2] Thành công – nhân viên được tạo', function () {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json.isSuccess ?? json.IsSuccess).to.be.true;",
                  "        pm.collectionVariables.set('employeeIdRace002', pm.collectionVariables.get('raceEmployeeId2'));",
                  "    });",
                  "    console.log('REQUEST 2: THÀNH CÔNG (201)');",
                  "}",
                  "",
                  "if (pm.response.code === 400) {",
                  "    pm.test('[Race R2] Bị reject – trùng code', function () {",
                  "        const json = pm.response.json();",
                  "        const message = json.userMessage ?? json.UserMessage ?? json.data ?? json.Data ?? '';",
                  "        pm.expect(String(message)).to.include('Mã nhân viên đã tồn tại');",
                  "    });",
                  "    console.log('REQUEST 2: BỊ REJECT (400)');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeID\": \"{{raceEmployeeId2}}\",\n  \"employeeCode\": \"{{raceEmployeeCode}}\",\n  \"employeeName\": \"Race Test Nhan Vien 2\",\n  \"gender\": 0,\n  \"dateOfBirth\": \"1997-11-22\",\n  \"phoneNumber\": \"0911000002\",\n  \"email\": \"race2@misa.com\",\n  \"address\": \"HCM\",\n  \"departmentID\": \"{{raceDepartmentId}}\",\n  \"positionID\": \"{{racePositionId}}\",\n  \"salary\": 17000000,\n  \"hireDate\": \"2025-02-01\"\n}"
            },
            "url": {
              "raw": "{{collBaseUrl}}/api/Employees",
              "host": [
                "{{collBaseUrl}}"
              ],
              "path": [
                "api",
                "Employees"
              ]
            },
            "description": "⚠️ Chạy ĐỒNG THỜI với Request 1. Cùng employeeCode động `{{raceEmployeeCode}}`.\n\nKỳ vọng: Nếu Request 1 đã tạo thành công → Request này trả về 400 BadRequest."
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Cleanup",
      "item": [
        {
          "name": "[DELETE] Xóa Happy Employee (cleanup)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const id = pm.collectionVariables.get('employeeIdHappy01');",
                  "if (!id) { pm.collectionVariables.set('skipCleanupHappy', 'true'); } else { pm.collectionVariables.unset('skipCleanupHappy'); }"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.collectionVariables.get('skipCleanupHappy') === 'true') {",
                  "    pm.test('Skip cleanup happy vì không có employeeId', function () { pm.expect(true).to.be.true; });",
                  "    return;",
                  "}",
                  "pm.test('Xóa thành công 200 hoặc 204', function () {",
                  "    pm.expect([200, 204]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{collBaseUrl}}/api/Employees/{{employeeIdHappy01}}",
              "host": [
                "{{collBaseUrl}}"
              ],
              "path": [
                "api",
                "Employees",
                "{{employeeIdHappy01}}"
              ]
            },
            "description": "Dọn dẹp sau test. employeeId được tự động lấy từ response tạo employee."
          },
          "response": []
        },
        {
          "name": "[DELETE] Xóa Race Employee (cleanup)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const raceId = pm.collectionVariables.get('employeeIdRace001') || pm.collectionVariables.get('employeeIdRace002');",
                  "if (!raceId) {",
                  "  pm.collectionVariables.set('skipCleanupRace', 'true');",
                  "  pm.collectionVariables.set('employeeIdRaceCleanup', '00000000-0000-0000-0000-000000000000');",
                  "} else {",
                  "  pm.collectionVariables.unset('skipCleanupRace');",
                  "  pm.collectionVariables.set('employeeIdRaceCleanup', raceId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.collectionVariables.get('skipCleanupRace') === 'true') {",
                  "    pm.test('Skip cleanup race vì không có employeeId', function () { pm.expect(true).to.be.true; });",
                  "    return;",
                  "}",
                  "pm.test('Xóa thành công 200 hoặc 204', function () {",
                  "    pm.expect([200, 204]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{collBaseUrl}}/api/Employees/{{employeeIdRaceCleanup}}",
              "host": [
                "{{collBaseUrl}}"
              ],
              "path": [
                "api",
                "Employees",
                "{{employeeIdRaceCleanup}}"
              ]
            },
            "description": "Dọn dẹp dữ liệu race condition bằng employeeId tự bắt từ response của request race thành công."
          },
          "response": []
        }
      ]
    }
  ]
}