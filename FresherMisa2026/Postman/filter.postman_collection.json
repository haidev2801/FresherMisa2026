    {
      "name": "Task 2.2 - Employee Filter",
      "item": [
        {
          "name": "GET Employees/filter - lọc theo departmentId RND",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const expectedCount = Number(pm.collectionVariables.get('expectedRndEmployeeCount'));",
                  "const expectedDepartmentId = pm.collectionVariables.get('rndDepartmentId');",
                  "const getValue = (obj, keys) => { for (const key of keys) { if (obj && Object.prototype.hasOwnProperty.call(obj, key)) return obj[key]; } return undefined; };",
                  "pm.test('Status code là 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response thành công', function () { pm.expect(json.isSuccess).to.eql(true); });",
                  "pm.test('Data là mảng', function () { pm.expect(Array.isArray(json.data)).to.eql(true); });",
                  "pm.test('Số lượng nhân viên phòng RND đúng theo seed data', function () { pm.expect(json.data.length).to.eql(expectedCount); });",
                  "pm.test('Tất cả nhân viên thuộc phòng RND', function () { json.data.forEach(item => pm.expect(getValue(item, ['departmentID', 'DepartmentID', 'departmentId', 'DepartmentId'])).to.eql(expectedDepartmentId)); });",
                  "pm.test('Có chứa một số mã nhân viên mẫu', function () { const codes = json.data.map(item => getValue(item, ['employeeCode', 'EmployeeCode'])); pm.expect(codes).to.include('EMP001'); pm.expect(codes).to.include('EMP014'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/Employees/filter?departmentId={{rndDepartmentId}}"
          },
          "response": []
        },
        {
          "name": "GET Employees/filter - lọc nhiều điều kiện",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const getValue = (obj, keys) => { for (const key of keys) { if (obj && Object.prototype.hasOwnProperty.call(obj, key)) return obj[key]; } return undefined; };",
                  "const expectedCodes = ['EMP001', 'EMP012', 'EMP014'];",
                  "pm.test('Status code là 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response thành công', function () { pm.expect(json.isSuccess).to.eql(true); });",
                  "pm.test('Data là mảng', function () { pm.expect(Array.isArray(json.data)).to.eql(true); });",
                  "pm.test('Trả về đúng 3 nhân viên theo điều kiện lọc', function () { pm.expect(json.data.length).to.eql(3); });",
                  "pm.test('Danh sách mã nhân viên đúng', function () { const actualCodes = json.data.map(item => getValue(item, ['employeeCode', 'EmployeeCode'])).sort(); pm.expect(actualCodes).to.eql(expectedCodes.sort()); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/Employees/filter?departmentId={{rndDepartmentId}}&positionId={{developerPositionId}}&salaryFrom=17000000&salaryTo=20000000&gender=1&hireDateFrom=2026-04-15T00:00:00&hireDateTo=2026-04-16T23:59:59"
