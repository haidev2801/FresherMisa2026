        {
          "name": "POST Employees - thiếu trường bắt buộc",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const message = `${json.data ?? ''} ${json.userMessage ?? ''} ${json.devMessage ?? ''}`;",
                  "pm.test('Status code là 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Response báo thất bại', function () { pm.expect(json.isSuccess).to.eql(false); });",
                  "pm.test('Code là 400', function () { pm.expect(json.code).to.eql(400); });",
                  "pm.test('Có lỗi cho EmployeeCode', function () { pm.expect(message).to.include('Trường Mã nhân viên bắt buộc nhập'); });",
                  "pm.test('Có lỗi cho EmployeeName', function () { pm.expect(message).to.satisfy(m => m.includes('Trường Tên nhân viên bắt buộc nhập') || m.includes('Tên nhân viên không được để trống')); });",
                  "pm.test('Có lỗi cho DepartmentID', function () { pm.expect(message).to.include('Phòng ban không được để trống'); });",
                  "pm.test('Có lỗi cho PositionID', function () { pm.expect(message).to.include('Vị trí không được để trống'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
