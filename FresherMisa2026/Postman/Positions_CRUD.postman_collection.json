    {
      "name": "07. POST - Create Position Success",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"positionCode\": \"{{newPositionCode}}\",\n  \"positionName\": \"{{newPositionName}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Positions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Positions"
          ]
        },
        "description": "Tạo mới position hợp lệ, tự sinh code ngẫu nhiên để tránh trùng."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now().toString().slice(-6);",
              "pm.collectionVariables.set('newPositionCode', `POS${suffix}`);",
              "pm.collectionVariables.set('newPositionName', `Position ${suffix}`);",
              "pm.collectionVariables.set('updatedPositionCode', `UPD${suffix}`);",
              "pm.collectionVariables.set('updatedPositionName', `Updated Position ${suffix}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Create response is success', function () {",
              "    pm.expect(json.isSuccess).to.eql(true);",
              "    pm.expect(json.code).to.eql(200);",
              "});",
              "",
              "pm.collectionVariables.set('createdPositionId', '');"
            ]
          }
        }
      ],
      "response": []
    },
