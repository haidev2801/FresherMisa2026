          "raw": "{\n  \"employeeCode\": \"{{newEmployeeCode}}\",\n  \"employeeName\": \"{{newEmployeeName}}\",\n  \"gender\": 1,\n  \"dateOfBirth\": \"1998-01-01\",\n  \"phoneNumber\": \"0901234567\",\n  \"email\": \"{{newEmployeeEmail}}\",\n  \"address\": \"Ha Noi\",\n  \"departmentID\": \"{{departmentId}}\",\n  \"positionID\": \"{{positionId}}\",\n  \"salary\": 12000000,\n  \"createdDate\": \"2026-04-16T09:00:00\"\n}"
