      "name": "05. POST - Create Employee Success",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now().toString().slice(-6);",
              "pm.collectionVariables.set('newEmployeeCode', `EMP${suffix}`);",
              "pm.collectionVariables.set('newEmployeeName', `Employee ${suffix}`);",
              "pm.collectionVariables.set('newEmployeeEmail', `employee${suffix}@test.com`);",
              "pm.collectionVariables.set('updatedEmployeeCode', `UPD${suffix}`);",
              "pm.collectionVariables.set('updatedEmployeeName', `Updated Employee ${suffix}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.test('Created', function () {",
              "  pm.expect(json.isSuccess).to.eql(true);",
              "  pm.expect(json.code).to.eql(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
